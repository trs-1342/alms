rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Yardımcı fonksiyonlar ─────────────────────────────────
    function isAuthed() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthed() &&
        exists(/databases/$(database)/documents/students/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/students/$(request.auth.uid)).data.is_admin == true;
    }

    function isSuperAdmin() {
      return isAdmin() &&
        get(/databases/$(database)/documents/students/$(request.auth.uid)).data.admin_role == "super";
    }

    function isDeptAdmin(dept) {
      return isAdmin() &&
        get(/databases/$(database)/documents/students/$(request.auth.uid)).data.admin_role == "dept" &&
        get(/databases/$(database)/documents/students/$(request.auth.uid)).data.admin_department == dept;
    }

    function canManageTopic(topicDept) {
      return isSuperAdmin() || isDeptAdmin(topicDept);
    }

    // ── Öğrenci kayıtları ─────────────────────────────────────
    // Doc ID = Firebase UID → request.auth.uid ile karşılaştırılır.
    match /students/{studentId} {
      // Kendi kaydını veya admin tüm kayıtları okuyabilir
      allow read: if request.auth.uid == studentId || isAdmin();

      // Sadece kendi kaydını oluşturabilir
      allow create: if request.auth.uid == studentId;

      // Kendi kaydını (admin alanları hariç) güncelleyebilir
      // Super admin her alanı güncelleyebilir
      allow update: if (
        request.auth.uid == studentId &&
        !request.resource.data.diff(resource.data)
          .affectedKeys().hasAny(["is_admin", "admin_role", "admin_faculty", "admin_department"])
      ) || isSuperAdmin();

      // Sadece super admin silebilir
      allow delete: if isSuperAdmin();
    }

    // ── Sınav konuları ────────────────────────────────────────
    match /topics/{topicId} {
      allow list: if isAuthed();
      allow get: if isAuthed() && (
        resource.data.status != "rejected" ||
        canManageTopic(resource.data.department)
      );
      allow create: if isAuthed() &&
        request.resource.data.keys().hasAll(
          ["exam_type", "course_code", "topics_list", "submitted_by",
           "submitted_at", "votes_up", "votes_down", "status"]
        ) &&
        request.resource.data.status == "active" &&
        request.resource.data.votes_up == 0 &&
        request.resource.data.votes_down == 0;
      allow update: if isAuthed() && (
        request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly(["votes_up", "votes_down", "trust_score"])
        ||
        (canManageTopic(resource.data.department) &&
         request.resource.data.diff(resource.data)
           .affectedKeys()
           .hasOnly(["status", "admin_note", "reviewed_at", "reviewed_by"]))
      );
      allow delete: if canManageTopic(resource.data.department);
    }

    // ── Oylar ─────────────────────────────────────────────────
    match /votes/{voteId} {
      allow read:   if isAuthed();
      allow create: if isAuthed() &&
        request.resource.data.keys().hasAll(
          ["student_hash", "topic_id", "vote", "voted_at"]
        ) &&
        request.resource.data.vote in ["up", "down"];
      allow update: if false;
      allow delete: if isSuperAdmin();
    }

    // ── Uygulama yapılandırması ────────────────────────────────
    // Sadece Firebase Console / Admin SDK yazabilir (istemci yazamaz)
    match /app_config/{doc} {
      allow read:  if isAuthed();
      allow write: if false;
    }

  }
}
